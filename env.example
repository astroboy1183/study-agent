# Copy to .env and fill in, then: chmod 600 .env
# Required — from @BotFather and your numeric chat id:
STUDY_BOT_TOKEN=123456:ABC-your-botfather-token
STUDY_CHAT_ID=123456789

# Summaries — needed for the Claude-written study briefs:
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5
SUMMARY_MAX_TOKENS=4000

# Obsidian vault integration (paths on THIS machine):
VAULT_LOG=/home/jayanth/Desktop/Jayanth-Vault/01-Learning/Study-Log.md
VAULT_SUMMARIES=/home/jayanth/Desktop/Jayanth-Vault/01-Learning/Summaries
# Vault git repo root — if set, the agent commits+pushes the vault on /done (keep this repo PRIVATE):
VAULT_REPO=/home/jayanth/Desktop/Jayanth-Vault

# When the daily messages fire:
# Optional launch gate — no messages before this ISO date. Blank = start any day, immediately:
START_DATE=
REMIND_TIME=07:30
REVIEW_TIME=21:30
